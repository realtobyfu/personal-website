---
import type { CollectionEntry } from 'astro:content';
import BackLink from './BackLink.astro';
import SiteHeader from './SiteHeader.astro';
import PostNav from './PostNav.astro';
import Carousel from './Carousel';

interface Props {
  post: CollectionEntry<'blog'> | CollectionEntry<'writing'>;
  prev?: CollectionEntry<'blog'> | CollectionEntry<'writing'> | null;
  next?: CollectionEntry<'blog'> | CollectionEntry<'writing'> | null;
  currentPage?: 'home' | 'essays';
  backHref?: string;
  backLabel?: string;
  basePath?: string;
}

const { post, prev, next, currentPage = 'essays', backHref = '/blog', backLabel = 'Essays', basePath = '/blog' } = Astro.props;
const { title, date, location, tag } = post.data;
const isTechnical = post.collection === 'writing';

// Format date as "MMM YYYY"
const formattedDate = date.toLocaleDateString('en-US', {
  month: 'short',
  year: 'numeric',
  timeZone: 'UTC',
}).toUpperCase();
---

<div class="blog-container">
  <SiteHeader currentPage={currentPage} />

  <header class="blog-header">
    <BackLink href={backHref} label={backLabel} />
  </header>

  <main class="blog-content">
    <article>
      <header class="post-header">
        <div class="post-meta-row">
          <span class="meta-date">{formattedDate}</span>
          {location && <span class="meta-location">{location}</span>}
          {tag && <span class="meta-tag">{tag}</span>}
        </div>
        <h1 class="post-title" set:html={title} />
        <div class="article-rule"></div>
      </header>

      <div class={`prose${isTechnical ? ' prose--technical' : ''}`}>
        <slot />
      </div>
    </article>

    <PostNav prev={prev} next={next} basePath={basePath} />
  </main>
</div>

<!-- Carousel collects prose images dynamically -->
<Carousel client:load />

{isTechnical && (
  <>
    <div class="reading-progress" id="reading-progress" />
    <script>
      // Reading progress bar
      const bar = document.getElementById('reading-progress');
      if (bar) {
        const update = () => {
          const scrollTop = window.scrollY;
          const docHeight = document.documentElement.scrollHeight - window.innerHeight;
          bar.style.width = docHeight > 0 ? `${(scrollTop / docHeight) * 100}%` : '0%';
        };
        window.addEventListener('scroll', update, { passive: true });
        update();
      }

      // Section anchor links
      document.querySelectorAll('.prose h2, .prose h3').forEach((heading) => {
        const text = heading.textContent ?? '';
        const id = text.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/^-|-$/g, '');
        heading.id = id;
        const a = document.createElement('a');
        a.href = `#${id}`;
        a.className = 'anchor-link';
        a.textContent = '§';
        a.setAttribute('aria-hidden', 'true');
        heading.appendChild(a);
      });

    </script>
  </>
)}
