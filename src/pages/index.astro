---
import { getCollection } from 'astro:content';
import BlogLayout from '../layouts/BlogLayout.astro';
import SiteHeader from '../components/blog/SiteHeader.astro';
import PostList from '../components/blog/PostList.astro';

const posts = await getCollection('writing', ({ data }) => !data.draft);
const sortedPosts = posts.sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BlogLayout title="Tobias Fu — Technical Writing" description="Technical writing by Tobias Fu on AI engineering, iOS development, and software craft.">
  <div class="blog-container">
    <SiteHeader currentPage="home" />
    <header class="blog-index-header">
    </header>
    <PostList posts={sortedPosts} basePath="/writing" />
  </div>
</BlogLayout>
